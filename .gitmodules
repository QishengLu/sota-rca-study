# 6 个 RCA agent submodules
# URL 在用户 fork 后填入 (WP1 阶段占位)
#
# 用法:
#   git submodule add <forked-url> frameworks/<name>
#   git submodule update --init --recursive
#
# 占位条目，等用户提供 fork URL 后取消注释:

# [submodule "frameworks/thinkdepthai"]
#     path = frameworks/thinkdepthai
#     url = https://github.com/LGU-SE-Internal/ThinkDepthAI.git
#     branch = main

# [submodule "frameworks/aiq"]
#     path = frameworks/aiq
