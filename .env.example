# ====================================================================
# sota-rca-study — Environment Variables (copy to .env, do NOT commit)
# ====================================================================

# --- Database (PostgreSQL or SQLite) ---
# Default: docker compose 起的本地 PG 5433
UTU_DB_URL=postgresql://postgres:postgres@localhost:5433/sota_rca_study
# 或本地 SQLite (单 agent 快速试):
# UTU_DB_URL=sqlite:///./results/local.db

POSTGRES_PORT=5433

# --- LLM 配置 (核心契约, 跟 ThinkDepthAI 一致) ---
# 由 orchestrator 按 matrix.yaml + catalog.yaml 自动注入；
# 单次手动跑也可以直接设这 4 个变量。
UTU_LLM_TYPE=chat.completions
UTU_LLM_MODEL=claude-sonnet-4-6
UTU_LLM_BASE_URL=https://api.shubiaobiao.cn/v1
UTU_LLM_API_KEY=

# --- 各 Provider API Keys (按需填) ---
# Anthropic / shubiaobiao proxy
SHUBIAOBIAO_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google Gemini
GOOGLE_API_KEY=
# 阿里云通义千问
DASHSCOPE_API_KEY=
# 智谱 GLM
ZHIPU_API_KEY=
# Moonshot Kimi
MOONSHOT_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=

# --- ClaudeCode CLI 专用 (走 Anthropic 兼容端点) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- Dataset (HuggingFace) ---
# 可选: 离线 mirror 加速
HF_ENDPOINT=https://huggingface.co
HF_HOME=~/.cache/huggingface

# --- Tracker 行为 ---
# 默认 actual (能 hook 就 hook); estimated 强制走字符数估算 fallback
SOTA_RCA_TRACKER_MODE=actual

# --- Dashboard ---
DASHBOARD_PORT=8001
DASHBOARD_MODE=prod   # prod | demo | dev
